rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reusable Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'abdulrahmannabudaqqa@gmail.com' || request.auth.token.email == 'aboudfdgreat@gmail.com') && 
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Site Config: Anyone can read, only admin can write
    match /site_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products: Anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tenders: Anyone can create, only admin can read/write
    match /tenders/{tenderId} {
      allow read, update, delete: if isAdmin();
      allow create: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
